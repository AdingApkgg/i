# Sample Caddy config for the prod stack (compose.prod.yaml binds app ports to
# 127.0.0.1). Adjust domains, then point your reverse proxy at these.
#
# Caddy auto-provisions HTTPS. If you already run another reverse proxy
# (nginx/traefik), mirror this routing instead.

# Public site (home / blog / music / gal / ...)
example.com {
	reverse_proxy 127.0.0.1:3000
}

# Backend API
api.example.com {
	reverse_proxy 127.0.0.1:8080
}

# Admin CMS (lock this down — basic auth / IP allowlist / VPN)
admin.example.com {
	reverse_proxy 127.0.0.1:3001
}
