# Copy to .env for local dev / prod. Defaults match compose.yaml service names.
#
# ⚠️  BETTER_AUTH_SECRET / ADMIN_PASSWORD are DEV placeholders — override before
#     any non-local deploy.

# --- Postgres ---
POSTGRES_USER=i
POSTGRES_PASSWORD=i
POSTGRES_DB=i
# Inside compose the host is the service name `db`; the Prisma pg adapter uses this.
DATABASE_URL=postgres://i:i@db:5432/i

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- better-auth ---
# 32+ char random secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-32-chars-or-more
# Public origin of the site (used for auth callbacks + trusted origins).
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# First-run admin bootstrap (seed promotes this email to role=owner).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# Optional visitor OAuth (leave blank to disable).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Object storage (MinIO / S3, for gallery uploads) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=gallery
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# --- Host port overrides (this machine already uses 5432/6379/8080/3000) ---
# WEB_PORT=3000
# DB_PORT=5432
# REDIS_PORT=6379
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
