# Copy to .env for `docker compose up`. These defaults match compose.yaml.
#
# ⚠️  JWT_SECRET and ADMIN_PASSWORD below are DEV-ONLY placeholders.
#     They MUST be overridden with real secrets before any non-local deploy.

# --- Postgres ---
POSTGRES_USER=i
POSTGRES_PASSWORD=i
POSTGRES_DB=i

# --- Backend (services/api) ---
# Inside compose the hostnames are the service names (db / redis).
DATABASE_URL=postgres://i:i@db:5432/i
REDIS_URL=redis://redis:6379
API_BIND=0.0.0.0:8080
JWT_SECRET=dev-change-me
ADMIN_PASSWORD=admin
RUST_LOG=info,api=debug,tower_http=debug

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# --- Frontend (browser-side, so use localhost) ---
# If you change API_PORT below, update this to match.
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Host port overrides (this machine may already use 5432/6379/8080) ---
# Uncomment + change any that collide with existing services.
# DB_PORT=5432
# REDIS_PORT=6379
# API_PORT=8080
# WEB_PORT=3000
# ADMIN_PORT=3001
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
