# Copy to .env for `docker compose up`. These defaults match compose.yaml.
#
# ⚠️  JWT_SECRET and ADMIN_PASSWORD below are DEV-ONLY placeholders.
#     They MUST be overridden with real secrets before any non-local deploy.

# --- Build (prod image builds via compose.prod.yaml) ---
# Build api + web + admin CONCURRENTLY and share one BuildKit cache store.
# Big win on this 128-core host; harmless elsewhere.
COMPOSE_BAKE=true

# --- Postgres ---
POSTGRES_USER=i
POSTGRES_PASSWORD=i
POSTGRES_DB=i

# --- Backend (services/api) ---
# Inside compose the hostnames are the service names (db / redis).
DATABASE_URL=postgres://i:i@db:5432/i
REDIS_URL=redis://redis:6379
API_BIND=0.0.0.0:8080
JWT_SECRET=dev-change-me
ADMIN_PASSWORD=admin
RUST_LOG=info,api=debug,tower_http=debug
# CORS allow-list (comma-separated). Empty = permissive (fine for local dev and
# same-origin nginx deploys). Set to your public origin(s) before going public:
# CORS_ALLOWED_ORIGINS=https://i.example.com,https://www.i.example.com

# --- MinIO (S3-compatible object storage) ---
# The api reaches minio over the compose network (service name + internal port).
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_BUCKET=gallery

# --- Frontend (browser-side, so use localhost) ---
# If you change API_PORT below, update this to match.
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Host port overrides (this machine may already use 5432/6379/8080) ---
# Uncomment + change any that collide with existing services.
# DB_PORT=5432
# REDIS_PORT=6379
# API_PORT=8080
# WEB_PORT=3000
# ADMIN_PORT=3001
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
