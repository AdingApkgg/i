{
  "name": "i",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --concurrency=100%",
    "build:web": "turbo run build --filter=web",
    "build:admin": "turbo run build --filter=admin",
    "typecheck": "turbo run typecheck --concurrency=100%",
    "dev:web": "bun run --filter web dev",
    "dev:admin": "bun run --filter admin dev"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5"
  }
}
