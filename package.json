{
  "name": "i",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate",
    "db:push": "bun --filter @i/db db:push",
    "db:migrate": "bun --filter @i/db db:migrate",
    "db:studio": "bun --filter @i/db db:studio",
    "db:seed": "bun --filter @i/db db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "turbo": "^2.5.9",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "@live2d-loader/core": "0.1.1",
    "@live2d-loader/renderer-webgl": "0.1.1"
  }
}
