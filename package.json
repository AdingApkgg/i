{
  "name": "i",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --concurrency=100%",
    "build:web": "turbo run build --filter=web",
    "build:admin": "turbo run build --filter=admin",
    "typecheck": "turbo run typecheck --concurrency=100%",
    "dev:web": "bun run --filter web dev",
    "dev:admin": "bun run --filter admin dev"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5"
  },
  "//overrides": "@live2d-loader 0.1.1 published with `workspace:*` transitive deps (a publish-config bug in the live2d-loader repo). Pin them to 0.1.1 so bun can resolve them from npm.",
  "overrides": {
    "@live2d-loader/core": "0.1.1",
    "@live2d-loader/renderer-webgl": "0.1.1"
  }
}
