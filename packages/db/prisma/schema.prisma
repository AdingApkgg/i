// i — personal space, v2 (Next.js full-stack).
// Prisma 7 with the `prisma-client` generator + pg driver adapter.
// Auth models mirror better-auth's expected schema.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== Auth (better-auth) ====================

model User {
  id            String    @id
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  role          String    @default("user") // "user" | "admin" | "owner"
  banned        Boolean   @default(false)
  banReason     String?
  banExpiresAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  comments Comment[]

  @@index([email])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ==================== Blog ====================

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  contentMd   String    @db.Text
  coverUrl    String?
  tags        String[]  @default([])
  status      String    @default("draft") // "draft" | "published"
  publishedAt DateTime?
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments Comment[]

  @@index([status, publishedAt])
}

// ==================== Comments (self-hosted, visitor identity) ====================

model Comment {
  id        String   @id @default(cuid())
  // Generic attach point: a page path so comments can hang off any page
  // (blog post, gallery item, etc.). postId is set when it's a blog comment.
  path      String
  contentMd String   @db.Text
  status    String   @default("visible") // "visible" | "pending" | "spam" | "deleted"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment? @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentThread")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([path, createdAt])
  @@index([postId])
}

// ==================== 音乐 (music) ====================

model Track {
  id        String   @id @default(cuid())
  title     String
  artist    String?
  album     String?
  status    String   @default("在听") // 在听 | 听过 | 想听
  rating    Int?
  coverUrl  String?
  link      String?
  note      String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// ==================== 影视 (movie) ====================

model Movie {
  id        String   @id @default(cuid())
  title     String
  category  String?  // 电影 / 剧集…
  status    String   @default("在看") // 在看 | 看过 | 想看
  rating    Int?
  year      Int?
  coverUrl  String?
  link      String?
  note      String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// ==================== 视觉小说 / Galgame (vn) ====================

model Vn {
  id        String   @id @default(cuid())
  title     String
  brand     String?
  status    String   @default("在玩") // 在玩 | 通关 | 想玩 | 搁置
  rating    Int?
  playHours Int?
  coverUrl  String?
  link      String?
  note      String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// ==================== 东方 (touhou) ====================

model Touhou {
  id        String   @id @default(cuid())
  title     String
  category  String?  // game | music | print | doujin
  status    String   @default("收藏")
  rating    Int?
  coverUrl  String?
  link      String?
  note      String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, createdAt])
}

// ==================== 设备 (device) ====================

model Device {
  id        String   @id @default(cuid())
  name      String
  category  String?  // 手机 / 电脑…
  spec      String?
  status    String   @default("在用") // 在用 | 退役 | 想要
  acquired  String?  // 入手日期 (YYYY-MM-DD, free text)
  link      String?
  note      String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// ==================== 相册 (gallery) ====================

model Photo {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  thumbUrl    String?
  description String?  @db.Text
  takenAt     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

// ==================== 说说 (moments) ====================

model Moment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  mood      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

// ==================== 友链 (friends) ====================

model Friend {
  id          String   @id @default(cuid())
  name        String
  url         String
  avatarUrl   String?
  description String?  @db.Text
  status      String   @default("active") // active | pending
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, sortOrder])
}

// ==================== 监控 (monitor) ====================

model Monitor {
  id          String    @id @default(cuid())
  name        String
  target      String    // https://… or host:port
  kind        String    @default("http") // http | tcp
  intervalSec Int       @default(60)
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  checks MonitorCheck[]

  @@index([enabled, kind])
}

model MonitorCheck {
  id         String   @id @default(cuid())
  monitorId  String
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  ok         Boolean
  statusCode Int?
  latencyMs  Int?
  checkedAt  DateTime @default(now())

  @@index([monitorId, checkedAt])
}

// ==================== 舞萌 maimaiDX — 查分器对接 (maimai) ====================
// Scores are synced from 水鱼(diving-fish) / 落雪(lxns). Single-row config +
// profile + a records table (union of b50 + all scores).

model MaimaiConfig {
  id                   String   @id @default("current")
  source               String   @default("diving-fish") // "diving-fish" | "lxns" — active display source
  divingFishUsername   String?
  divingFishImportToken String?
  lxnsPersonalToken    String?
  updatedAt            DateTime @updatedAt
}

model MaimaiProfile {
  id        String   @id @default("current")
  source    String
  nickname  String
  rating    Int      @default(0)
  updatedAt DateTime @updatedAt
}

model MaimaiRecord {
  id          String   @id @default(cuid())
  source      String   // "diving-fish" | "lxns"
  songId      Int
  title       String
  type        String   // "standard" | "dx"
  levelIndex  Int      // 0 Basic .. 4 Re:MASTER
  levelLabel  String   // displayed level, e.g. "14+"
  ds          Float?   // chart constant 定数
  achievements Float   @default(0)
  dxScore     Int      @default(0)
  ra          Int      @default(0) // this chart's rating contribution
  fc          String?  // "" | fc | fcp | ap | app
  fs          String?  // "" | fs | fsp | fsd | fsdp | sync
  rate        String?  // sssp | sss | ...
  coverUrl    String?
  pool        String?  // "b35" | "b15" | null (null = only in all-scores)
  boardOrder  Int      @default(0) // order within its b50 pool
  syncedAt    DateTime @default(now())

  @@index([pool, boardOrder])
  @@index([achievements])
  @@unique([songId, type, levelIndex])
}
